# AI-ICES Environment Configuration
# Copy to .env and fill in production values

# App
APP_NAME=AI-ICES
APP_VERSION=1.0.0
DEBUG=false
LOG_LEVEL=INFO
LOG_FORMAT=json

# PostgreSQL
POSTGRES_HOST=localhost
POSTGRES_PORT=5432
POSTGRES_USER=ai_ices
POSTGRES_PASSWORD=change_me_in_production
POSTGRES_DB=ai_ices

# RabbitMQ
RABBITMQ_HOST=localhost
RABBITMQ_PORT=5672
RABBITMQ_USER=les_admin
RABBITMQ_PASSWORD=change_me_in_production
RABBITMQ_VHOST=les_vhost

# Redis
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=
REDIS_DB=0

# JWT
JWT_PRIVATE_KEY_PATH=/run/secrets/jwt_private_key.pem
JWT_PUBLIC_KEY_PATH=/run/secrets/jwt_public_key.pem
JWT_ALGORITHM=RS256
JWT_ACCESS_TOKEN_EXPIRE_MINUTES=15
JWT_REFRESH_TOKEN_EXPIRE_MINUTES=1440

# Service Ports
GATEWAY_PORT=8899
CORE_HUB_PORT=8000
GOVERNANCE_API_PORT=8080
DASHBOARD_BACKEND_PORT=3000

# Gateway
MILTER_TIMEOUT=3
MILTER_HOST=0.0.0.0

# Celery
CELERY_BROKER_URL=
CELERY_RESULT_BACKEND=redis://localhost:6379/1
CELERY_TASK_ALWAYS_EAGER=false
CELERY_WORKER_CONCURRENCY=4

# Security
SECRET_KEY=change_me_in_production
ENCRYPTION_KEY=change_me_in_production
TLS_ENABLED=true

# Monitoring
PROMETHEUS_ENABLED=true
SENTRY_DSN=

# External Services
THREAT_INTEL_API_KEY=
THREAT_INTEL_API_URL=

# Zimbra
ZIMBRA_SOAP_URL=https://mail.company.com/service/soap
ZIMBRA_ADMIN_USER=admin@company.com
ZIMBRA_ADMIN_PASSWORD=change_me_in_production
